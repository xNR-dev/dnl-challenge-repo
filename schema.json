{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HGB Disclosure Checklist",
  "description": "Schema for structured audit disclosure checklist under German GAAP (HGB), scoped to medium-sized GmbH (§ 267 Abs. 2 HGB)",
  "type": "object",
  "required": ["metadata", "checklist"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["entity_type", "size_class", "reporting_framework", "pl_format", "sections", "applicable_date"],
      "properties": {
        "entity_type": { "type": "string", "const": "GmbH — Mittelgroße Kapitalgesellschaft (§ 267 Abs. 2 HGB)" },
        "size_class": { "type": "string", "const": "medium (mittelgroß)" },
        "reporting_framework": { "type": "string", "const": "HGB §§ 264 ff." },
        "pl_format": { "type": "string", "const": "Gesamtkostenverfahren (§ 275 Abs. 1 HGB)" },
        "sections": {
          "type": "array",
          "items": { "type": "string" },
          "const": ["Bilanz", "GuV", "Anhang", "Lagebericht"]
        },
        "applicable_date": { "type": "string", "description": "Financial year end to which checklist applies" },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Items explicitly excluded"
        }
      }
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "section", "sub_section", "disclosure_item", "hgb_reference", "obligation", "completeness_prompt"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]+-[0-9]{3}$",
            "description": "Unique identifier, e.g. BIL-001, GUV-001, ANH-001, LAG-001"
          },
          "section": {
            "type": "string",
            "enum": ["Bilanz", "GuV", "Anhang", "Lagebericht"]
          },
          "sub_section": {
            "type": "string",
            "description": "Logical grouping within the section, e.g. Anlagevermögen, Rückstellungen, Bewertungsmethoden"
          },
          "disclosure_item": {
            "type": "string",
            "description": "Closed audit question answerable with Yes / No / N/A"
          },
          "hgb_reference": {
            "type": "string",
            "description": "Primary statutory reference, e.g. § 285 Nr. 12 HGB"
          },
          "obligation": {
            "type": "string",
            "enum": ["M", "C"],
            "description": "M = always required for medium GmbH; C = conditional on trigger"
          },
          "trigger_condition": {
            "type": ["string", "null"],
            "description": "Required for C items — what triggers the requirement"
          },
          "completeness_prompt": {
            "type": "string",
            "description": "One-sentence instruction telling a validator agent what evidence to look for"
          }
        },
        "allOf": [
          {
            "if": { "properties": { "obligation": { "const": "C" } } },
            "then": { "required": ["trigger_condition"] }
          }
        ]
      }
    }
  }
}
